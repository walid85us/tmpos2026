// Phase 4.0 M0 — Fail-closed emergency Firestore security rules.
//
// Security contract (mirrors the owner-published live ruleset):
//   * The client may ONLY get its own /users/{uid} document. No user listing,
//     no client create/update/delete of user docs (so a user can never write the
//     authority-bearing `role` field, and no rule reads `role`/authority fields
//     from a user document — the old self-authored-admin path is dead).
//   * All client access to /tenants, nested memberships, nested invitations, and
//     /auditEvents is denied. Privileged reads/writes go through the trusted
//     server (Admin SDK, which bypasses these rules) and the canonical Postgres
//     authorization model — NOT client-writable Firestore fields or claims.
//   * Every unmatched path is explicitly denied (recursive default-deny).
// Static regression guard: tests/firestore/firestore.rules.static.test.mjs
// (Static source guard only — NOT an emulator semantic evaluation.)

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated()
        && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /tenants/{tenantId} {
      allow read, write: if false;
    }

    match /tenants/{tenantId}/memberships/{membershipId} {
      allow read, write: if false;
    }

    match /tenants/{tenantId}/invitations/{invitationId} {
      allow read, write: if false;
    }

    match /auditEvents/{eventId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
