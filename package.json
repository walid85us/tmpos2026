{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=5000 --host=0.0.0.0",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist-server/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server",
    "lint": "tsc --noEmit",
    "identity:api": "tsx server/platform-identity/server.ts",
    "identity:validate": "tsx scripts/supabase-identity-validate.ts",
    "identity:migrate": "tsx scripts/supabase-migrate.ts",
    "identity:whoami-check": "tsx scripts/diagnostics-supabase-whoami-check.ts",
    "backup:github": "bash scripts/github-safe-backup.sh",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "typecheck:contract": "node scripts/check-typecheck-contract.mjs",
    "lockfile:check": "node scripts/check-lockfile-portability.mjs",
    "test": "node scripts/run-tests.mjs && node scripts/run-frontend-tests.mjs",
    "test:existing": "node scripts/run-tests.mjs",
    "test:frontend": "node scripts/run-frontend-tests.mjs",
    "test:firestore:static": "node --test tests/firestore/firestore.rules.static.test.mjs",
    "test:firestore:emulator": "nix shell nixpkgs#jdk21_headless --command firebase emulators:exec --only firestore --project demo-tmpos-rules 'node --test tests/firestore/firestore.rules.emulator.test.mjs'",
    "build:check": "node scripts/check-build-integrity.mjs",
    "security:semgrep": "docker run --rm -v \"$PWD:/src:ro\" semgrep/semgrep@sha256:e04d2cb132288d90035db8791d64f610cb255b21e727b94db046243b30c01ae9 semgrep scan --config /src/.semgrep --metrics=off --quiet /src/src /src/server",
    "security:secrets": "docker run --rm -v \"$PWD:/src:ro\" zricethezav/gitleaks@sha256:0e99e8821643ea5b235718642b93bb32486af9c8162c8b8731f7cbdc951a7f46 detect --source=/src --no-git --redact --config=/src/.gitleaks.toml",
    "security:gates": "node scripts/check-security-gates.mjs",
    "forbidden:check": "node scripts/check-forbidden-artifacts.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "firebase-admin": "13.10.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "^10.4.21",
    "firebase-tools": "15.23.0",
    "jsdom": "29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@firebase/firestore": {
      "@grpc/grpc-js": "1.9.16"
    },
    "@google-cloud/storage@7.21.0": {
      "fast-xml-parser": "5.10.1"
    },
    "path-to-regexp@0.1.12": "0.1.13",
    "fast-uri@3": "3.1.4",
    "picomatch@4": "4.0.5",
    "ws@8": "8.21.1"
  }
}
